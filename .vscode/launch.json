{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Local Agent",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/app/main.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env.local",
      "args": [
        "--host",
        "0.0.0.0",
        "--port",
        "5000"
      ]
    }
  ]
}
